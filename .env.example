# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret

# ClickHouse
# Native port is 9000 inside the container, but host 9000 is taken by RustFS
# (S3), so docker-compose maps ClickHouse's native protocol to host 9009.
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9009
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# RustFS / S3-compatible Data Lake
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=data-lake
